<!-- ACCESS MODAL -->
<div id="accessModal" style="
  display:none;position:fixed;inset:0;z-index:10000;
  background:rgba(0,0,0,0.85);backdrop-filter:blur(12px);
  align-items:center;justify-content:center;
">
  <div style="
    background:#0F0F18;border:1px solid rgba(201,168,76,0.25);
    padding:52px 48px;max-width:460px;width:90%;position:relative;
    animation:fadeModalIn 0.4s ease;
  ">
    <!-- Top gold line -->
    <div style="position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,#C9A84C,transparent);"></div>
    <!-- Close -->
    <button onclick="closeAccessModal()" style="
      position:absolute;top:16px;right:20px;background:none;border:none;
      color:#5A5550;font-size:1.2rem;cursor:pointer;
    ">✕</button>

    <div style="text-align:center;margin-bottom:32px;">
      <div style="font-size:2rem;margin-bottom:12px;">✦</div>
      <h2 style="font-family:'Cormorant Garamond',serif;font-size:1.9rem;font-weight:300;margin-bottom:8px;">
        Accès à la Formation
      </h2>
      <p style="font-size:0.85rem;color:#9A9280;line-height:1.6;font-weight:300;">
        Entre ton code d'accès reçu après paiement pour accéder à la plateforme complète.
      </p>
    </div>

    <input
      type="text"
      id="accessCodeInput"
      placeholder="Ton code d'accès..."
      style="
        width:100%;background:#16161F;border:1px solid rgba(201,168,76,0.2);
        padding:14px 18px;font-family:'Outfit',sans-serif;font-size:1rem;
        color:#F0EDE8;outline:none;margin-bottom:10px;
        letter-spacing:0.1em;text-align:center;text-transform:uppercase;
      "
      onkeydown="if(event.key==='Enter')checkCode()"
    />
    <div id="accessError" style="
      font-size:0.8rem;color:#E74C3C;text-align:center;
      min-height:20px;margin-bottom:12px;
    "></div>

    <button onclick="checkCode()" style="
      width:100%;background:linear-gradient(135deg,#E8C97A,#C9A84C);
      color:#050505;padding:15px;font-weight:700;font-size:0.88rem;
      letter-spacing:0.15em;text-transform:uppercase;border:none;cursor:pointer;
      transition:all 0.3s;
    ">
      Accéder à ma formation →
    </button>

    <p style="text-align:center;margin-top:20px;font-size:0.75rem;color:#5A5550;">
      Pas encore de code ? <a href="#prix" onclick="closeAccessModal()" style="color:#C9A84C;text-decoration:none;">Voir le tarif →</a>
    </p>
  </div>
</div>

<style>
@keyframes fadeModalIn {
  from { opacity:0; transform:translateY(20px); }
  to   { opacity:1; transform:translateY(0); }
}
</style>

<script>
// Custom cursor
const cursor = document.getElementById('cursor');
const ring = document.getElementById('cursorRing');
let mouseX = 0, mouseY = 0;
let ringX = 0, ringY = 0;

document.addEventListener('mousemove', e => {
  mouseX = e.clientX;
  mouseY = e.clientY;
  cursor.style.left = mouseX - 4 + 'px';
  cursor.style.top = mouseY - 4 + 'px';
});

function animateRing() {
  ringX += (mouseX - ringX - 16) * 0.12;
  ringY += (mouseY - ringY - 16) * 0.12;
  ring.style.left = ringX + 'px';
  ring.style.top = ringY + 'px';
  requestAnimationFrame(animateRing);
}
animateRing();

document.querySelectorAll('a, button').forEach(el => {
  el.addEventListener('mouseenter', () => {
    cursor.style.transform = 'scale(2.5)';
    ring.style.width = '48px';
    ring.style.height = '48px';
  });
  el.addEventListener('mouseleave', () => {
    cursor.style.transform = 'scale(1)';
    ring.style.width = '32px';
    ring.style.height = '32px';
  });
});

// Intersection observer for reveal animations
const reveals = document.querySelectorAll('.reveal');
const observer = new IntersectionObserver(entries => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
    }
  });
}, { threshold: 0.1 });

reveals.forEach(el => observer.observe(el));

// === ACCESS MODAL ===
const VALID_CODES = {
  'IA2025':    'client',   // Code client standard
  'AKOUA2026': 'admin',    // Code admin Prisca
};

function openAccessModal() {
  const modal = document.getElementById('accessModal');
  modal.style.display = 'flex';
  setTimeout(() => document.getElementById('accessCodeInput').focus(), 100);
}

function closeAccessModal() {
  document.getElementById('accessModal').style.display = 'none';
  document.getElementById('accessError').textContent = '';
  document.getElementById('accessCodeInput').value = '';
}

function checkCode() {
  const input = document.getElementById('accessCodeInput').value.trim().toUpperCase();
  const errorEl = document.getElementById('accessError');

  if (!input) {
    errorEl.textContent = '⚠ Entre ton code d\'accès.';
    return;
  }

  if (VALID_CODES[input]) {
    // Save access in sessionStorage so platform.html can verify
    try { sessionStorage.setItem('ia_access', input); } catch(e){}
    try { sessionStorage.setItem('ia_role', VALID_CODES[input]); } catch(e){}
    errorEl.style.color = '#2ECC71';
    errorEl.textContent = '✓ Code validé ! Redirection...';
    setTimeout(() => { try { window.location.href = 'platform.html'; } catch(e){} }, 700);
  } else {
    errorEl.style.color = '#E74C3C';
    errorEl.textContent = '✕ Code invalide. Vérifie ton code ou contacte le support.';
    document.getElementById('accessCodeInput').style.borderColor = 'rgba(231,76,60,0.5)';
    setTimeout(() => {
      document.getElementById('accessCodeInput').style.borderColor = 'rgba(201,168,76,0.2)';
    }, 2000);
  }
}

// Close modal on backdrop click
document.getElementById('accessModal').addEventListener('click', function(e) {
  if (e.target === this) closeAccessModal();
});
</script>
</body>
</html>
